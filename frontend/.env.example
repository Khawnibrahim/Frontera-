# Supabase Auth + direct reads (must match backend SUPABASE_URL / DATABASE_URL project)
# If work-site dropdown is empty, these likely point at a different project than backend/.env
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Nest API — deployed Lambda (see backend stack Output ApiUrl) or local dev
# Deployed: https://<api-id>.execute-api.us-east-1.amazonaws.com
# Local:     http://localhost:3000
VITE_FRONTERA_API_URL=https://sjrya37yid.execute-api.us-east-1.amazonaws.com
